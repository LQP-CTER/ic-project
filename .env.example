# URL Web App Google Apps Script, phải kết thúc bằng /exec
VITE_GOOGLE_SHEETS_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Lưu ý: mọi biến VITE_* đều hiển thị cho trình duyệt. Chỉ dùng key Cerebras
# có quota giới hạn cho MVP nội bộ; không dùng một secret production lâu dài.
VITE_CEREBRAS_API_KEY=your_cerebras_api_key_here
VITE_CEREBRAS_MODEL=gpt-oss-120b